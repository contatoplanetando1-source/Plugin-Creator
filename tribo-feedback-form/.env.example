# Resend (https://resend.com) API key used to send form submissions by email.
RESEND_API_KEY=

# Optional: sender address. Must belong to a domain verified in your Resend account.
# Defaults to "Tribo V4 <onboarding@resend.dev>" (only deliverable to your own Resend account email until a domain is verified).
RESEND_FROM_EMAIL="Tribo V4 <feedback@seu-dominio-verificado.com>"
